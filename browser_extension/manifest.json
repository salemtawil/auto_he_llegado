{
  "manifest_version": 3,
  "name": "Auto He Llegado Observer",
  "version": "0.2.0",
  "description": "Capa de observacion y diagnostico para compinche.io y paripe.io.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_idle",
      "css": [
        "ui/overlay.css"
      ],
      "js": [
        "helpers/common.js",
        "detectors/language.js",
        "detectors/iframe.js",
        "detectors/phase.js",
        "ui/overlay.js",
        "explorer.js",
        "content.js"
      ]
    }
  ]
}
